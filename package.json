{
  "name": "xemubox-dashboard",
  "version": "0.0.1",
  "description": "Xbox-styled game picker for XemuBOX integration",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux",
    "build:deb": "electron-builder --linux deb",
    "pack": "electron-builder --dir"
  },
  "keywords": ["xbox", "emulation", "xemu", "dashboard"],
  "author": "bomkz",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "overrides": {
    "tar": ">=6.2.1"
  },
  "build": {
    "appId": "com.bomkz.xemubox-dashboard",
    "productName": "XemuBOX Dashboard",
    "artifactName":"xdash",
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Game"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.html",
      "config.json",
      "themes/**/*"
    ]
  }
}
